msgid "Could not decrypt file: unsupported encryption key version."
msgstr ""
"Datei konnte nicht entschlüsselt werden: Nicht unterstützte "
"Verschlüsselungsschlüsselversion."

#: includes/class-wg-plugin.php:1702
msgid "Could not read file."
msgstr "Datei konnte nicht gelesen werden."

#: includes/class-wg-plugin.php:1711
msgid "Could not decrypt file. Metadata integrity check failed."
msgstr ""
"Datei konnte nicht entschlüsselt werden. Integritätsprüfung der Metadaten "
"fehlgeschlagen."

#: includes/class-wg-plugin.php:1729
msgid ""
"Could not decrypt file. Metadata may be invalid or the key may have changed."
msgstr ""
"Datei konnte nicht entschlüsselt werden. Metadaten sind möglicherweise "
"ungültig oder der Schlüssel hat sich geändert."

#: includes/class-wg-plugin.php:1952 includes/class-wg-plugin.php:2109
msgid "You are not allowed to download files."
msgstr "Sie sind nicht berechtigt, Dateien herunterzuladen."

#: includes/class-wg-plugin.php:1958 includes/class-wg-plugin.php:1985
