msgid "Encrypted file is healthy and downloadable."
msgstr "Die verschlüsselte Datei ist intakt und kann heruntergeladen werden."

#: includes/class-wg-plugin.php:1413
msgid "Metadata file is missing. This upload cannot be decrypted."
msgstr ""
"Die Metadatendatei fehlt. Dieser Upload kann nicht entschlüsselt werden."

#: includes/class-wg-plugin.php:1417 includes/class-wg-plugin.php:1442
msgid ""
"Metadata looks damaged or unreadable. Download is currently unavailable."
msgstr ""
"Metadaten scheinen beschädigt oder unlesbar zu sein. Der Download ist "
"derzeit nicht verfügbar."

#: includes/class-wg-plugin.php:1423 includes/class-wg-plugin.php:1436
#: includes/class-wg-plugin.php:1451
msgid "Encrypted with a key version not available on this site."
msgstr ""
"Die Datei wurde mit einer auf dieser Website nicht verfügbaren "
"Schlüsselversion verschlüsselt."

#: includes/class-wg-plugin.php:1429
msgid "Could not read encrypted file data."
msgstr "Verschlüsselte Dateidaten konnten nicht gelesen werden."

#: includes/class-wg-plugin.php:1439
msgid ""
"Metadata integrity check failed. File metadata or blob appears modified."
msgstr ""
"Integritätsprüfung der Metadaten fehlgeschlagen. Metadaten oder Blob "
"scheinen verändert zu sein."

#: includes/class-wg-plugin.php:1454
msgid "Private metadata could not be decoded."
msgstr "Private Metadaten konnten nicht dekodiert werden."

#: includes/class-wg-plugin.php:1461
msgid "Decryption check failed. The file or metadata may be corrupted."
msgstr ""
"Entschlüsselungsprüfung fehlgeschlagen. Die Datei oder Metadaten könnten "
"beschädigt sein."

#: includes/class-wg-plugin.php:1465
msgid ""
"Download works, but metadata is from legacy plaintext format and should be "
"re-uploaded for better privacy."
msgstr ""
"Der Download funktioniert, aber die Metadaten stammen aus einem alten "
"Klartextformat und sollten für besseren Datenschutz neu hochgeladen werden."

#: includes/class-wg-plugin.php:1507
msgid ""
"Legacy plaintext file found. It is intentionally not served by this plugin."
msgstr ""
"Alte Klartextdatei gefunden. Sie wird von diesem Plugin absichtlich nicht "
"bereitgestellt."

#: includes/class-wg-plugin.php:1658
msgid "Invalid file."
msgstr "Ungültige Datei."

#: includes/class-wg-plugin.php:1663
msgid "File does not exist."
msgstr "Datei existiert nicht."

#: includes/class-wg-plugin.php:1669
msgid "Missing file metadata."
msgstr "Dateimetadaten fehlen."

#: includes/class-wg-plugin.php:1692 includes/class-wg-plugin.php:1714
#: includes/class-wg-plugin.php:1724
