# Exclude repository and handoff artifacts from release archives.
/.DS_Store export-ignore
/.gitignore export-ignore
/.gitattributes export-ignore
/README.md export-ignore
/CHANGELOG.md export-ignore
/docs export-ignore
/wedding_gallery/.DS_Store export-ignore

# Translation packaging rules:
# - keep runtime files in release (.mo/.po)
# - source template (.pot) can be excluded
/wedding_gallery/languages/wedding-gallery-de_DE.mo -export-ignore
/wedding_gallery/languages/wedding-gallery-de_DE.po -export-ignore
/wedding_gallery/languages/wedding-gallery.pot export-ignore
