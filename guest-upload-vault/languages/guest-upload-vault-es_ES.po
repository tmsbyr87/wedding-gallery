#. translators: %d: uploaded files count
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1021
#, php-format
msgid "%d file uploaded successfully."
msgid_plural "%d files uploaded successfully."
msgstr[0] "El archivo %d se cargó correctamente."
