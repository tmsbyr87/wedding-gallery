msgstr ""
"Configuración guardada. El tamaño máximo de carga se fijó en %d MB para que "
"coincida con los límites de seguridad del servidor/tiempo de ejecución."

#. translators: %d: deleted files count
#: guest-upload-vault/templates/admin-page.php:100
#, php-format
msgid "%d file was deleted."
msgstr "Se eliminó el archivo %d."

#: guest-upload-vault/templates/admin-page.php:108
