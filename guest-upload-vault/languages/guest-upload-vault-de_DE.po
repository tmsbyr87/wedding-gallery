#, php-format
msgid "%1$d files were deleted. %2$d files were skipped."
msgstr "%1$d Dateien wurden gelöscht. %2$d Dateien wurden übersprungen."

#: guest-upload-vault/templates/admin-page.php:137
msgid "No files could be deleted."
msgstr "Es konnten keine Dateien gelöscht werden."

#: guest-upload-vault/templates/admin-page.php:145
