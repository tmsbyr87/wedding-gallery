msgid "%1$d video was too large to upload (max %2$d MB)."
msgid_plural "%1$d videos were too large to upload (max %2$d MB)."
msgstr[0] ""
"La vidéo %1$d était trop volumineuse pour être mise en ligne (maximum %2$d "
"MB)."
msgstr[1] ""
"%1$d vidéos étaient trop volumineuses pour être mises en ligne (maximum %2$d "
"MB)."

#. translators: %1$d: rejected photos count, %2$d: max upload size in MB
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1087
#, php-format
msgid "%1$d photo was too large to upload (max %2$d MB)."
msgid_plural "%1$d photos were too large to upload (max %2$d MB)."
msgstr[0] ""
"La photo %1$d était trop grande pour être téléchargée (maximum %2$d MB)."
msgstr[1] ""
"%1$d photos étaient trop volumineuses pour être téléchargées (maximum %2$d "
"MB)."

#. translators: %1$d: rejected files count, %2$d: max upload size in MB
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1094
#, php-format
msgid "%1$d file was too large to upload (max %2$d MB)."
msgid_plural "%1$d files were too large to upload (max %2$d MB)."
msgstr[0] ""
"Le fichier %1$d était trop volumineux pour être téléchargé (max %2$d MB)."
msgstr[1] ""
"Les fichiers %1$d étaient trop volumineux pour être téléchargés (maximum "
"%2$d MB)."

#. translators: %d: unsupported files count
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1104
#, php-format
msgid "%d file was not supported."
msgid_plural "%d files were not supported."
msgstr[0] "Le fichier %d n'était pas pris en charge."
msgstr[1] "Les fichiers %d n'étaient pas pris en charge."

#. translators: %d: files that could not be uploaded
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1112
#, php-format
msgid "%d file could not be uploaded. Please try again."
msgid_plural "%d files could not be uploaded. Please try again."
msgstr[0] "Le fichier %d n'a pas pu être téléchargé. Veuillez réessayer."
msgstr[1] "Les fichiers %d n'ont pas pu être téléchargés. Veuillez réessayer."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1257
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1910
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:2039
msgid "You are not allowed to access this page."
msgstr "Vous n'êtes pas autorisé à accéder à cette page."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1402
msgid "Encrypted file is healthy and downloadable."
msgstr "Le fichier crypté est sain et téléchargeable."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1413
msgid "Metadata file is missing. This upload cannot be decrypted."
msgstr ""
"Le fichier de métadonnées est manquant. Ce téléchargement ne peut pas être "
"déchiffré."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1417
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1442
msgid ""
"Metadata looks damaged or unreadable. Download is currently unavailable."
msgstr ""
"Les métadonnées semblent endommagées ou illisibles. Le téléchargement est "
"actuellement indisponible."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1423
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1436
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1451
msgid "Encrypted with a key version not available on this site."
msgstr "Chiffré avec une version de clé non disponible sur ce site."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1429
msgid "Could not read encrypted file data."
msgstr "Impossible de lire les données du fichier crypté."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1439
msgid ""
"Metadata integrity check failed. File metadata or blob appears modified."
msgstr ""
"La vérification de l'intégrité des métadonnées a échoué. Les métadonnées du "
"fichier ou le blob semblent modifiés."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1454
msgid "Private metadata could not be decoded."
msgstr "Les métadonnées privées n'ont pas pu être décodées."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1461
msgid "Decryption check failed. The file or metadata may be corrupted."
msgstr ""
"La vérification du décryptage a échoué. Le fichier ou les métadonnées "
"peuvent être corrompus."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1465
msgid ""
"Download works, but metadata is from legacy plaintext format and should be "
"re-uploaded for better privacy."
msgstr ""
"Le téléchargement fonctionne, mais les métadonnées proviennent du format de "
"texte brut existant et doivent être téléchargées à nouveau pour une "
"meilleure confidentialité."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1507
msgid ""
"Legacy plaintext file found. It is intentionally not served by this plugin."
msgstr ""
"Fichier en texte brut hérité trouvé. Il n'est intentionnellement pas servi "
"par ce plugin."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1658
msgid "Invalid file."
msgstr "Fichier invalide."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1663
msgid "File does not exist."
msgstr "Le fichier n'existe pas."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1669
msgid "Missing file metadata."
msgstr "Métadonnées de fichier manquantes."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1692
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1714
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1724
msgid "Invalid file metadata."
msgstr "Métadonnées de fichier non valides."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1697
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1708
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1721
msgid "Could not decrypt file: unsupported encryption key version."
msgstr ""
"Impossible de déchiffrer le fichier: version de clé de chiffrement non prise "
"en charge."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1702
msgid "Could not read file."
msgstr "Impossible de lire le fichier."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1711
msgid "Could not decrypt file. Metadata integrity check failed."
msgstr ""
"Impossible de déchiffrer le fichier. La vérification de l'intégrité des "
"métadonnées a échoué."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1729
msgid ""
"Could not decrypt file. Metadata may be invalid or the key may have changed."
msgstr ""
"Impossible de déchiffrer le fichier. Les métadonnées peuvent être invalides "
"ou la clé peut avoir changé."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1952
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:2109
msgid "You are not allowed to download files."
msgstr "Vous n'êtes pas autorisé à télécharger des fichiers."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1958
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1985
msgid "Missing file."
msgstr "Fichier manquant."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1963
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1990
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:2023
msgid "Invalid security token."
msgstr "Jeton de sécurité invalide."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:1979
msgid "You are not allowed to access this file."
msgstr "Vous n'êtes pas autorisé à accéder à ce fichier."

#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:2006
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:2055
msgid "You are not allowed to delete files."
msgstr "Vous n'êtes pas autorisé à supprimer des fichiers."

#. translators: %d: skipped files count in ZIP export
#: guest-upload-vault/includes/class-guest-upload-vault-plugin.php:2168
#, php-format
msgid "%d file(s) were skipped because they are not currently decryptable."
msgstr ""
"Les fichiers %d ont été ignorés car ils ne sont pas actuellement "
"déchiffrables."

#: guest-upload-vault/templates/admin-page.php:60
msgid "Guest Upload Vault logo"
msgstr "Logo Guest Upload Vault"

#: guest-upload-vault/templates/admin-page.php:63
