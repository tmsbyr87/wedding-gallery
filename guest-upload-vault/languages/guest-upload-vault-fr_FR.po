#. translators: %d: effective max upload in MB
#: guest-upload-vault/templates/admin-page.php:88
#, php-format
msgid ""
"Settings saved. Max upload size was clamped to %d MB to match server/runtime "
"safety limits."
msgstr ""
"Paramètres enregistrés. La taille maximale de téléchargement a été limitée à "
"%d MB pour correspondre aux limites de sécurité du serveur/d'exécution."

#. translators: %d: deleted files count
#: guest-upload-vault/templates/admin-page.php:100
#, php-format
msgid "%d file was deleted."
msgstr "Le fichier %d a été supprimé."

#: guest-upload-vault/templates/admin-page.php:108
msgid "File could not be deleted."
msgstr "Le fichier n'a pas pu être supprimé."

#. translators: %d: deleted files count
#: guest-upload-vault/templates/admin-page.php:116
#, php-format
msgid "%d files were deleted."
msgstr "Les fichiers %d ont été supprimés."

#. translators: 1: deleted files count, 2: skipped files count
#: guest-upload-vault/templates/admin-page.php:128
#, php-format
msgid "%1$d files were deleted. %2$d files were skipped."
msgstr ""
"Les fichiers %1$d ont été supprimés. Les fichiers %2$d ont été ignorés."

#: guest-upload-vault/templates/admin-page.php:137
msgid "No files could be deleted."
msgstr "Aucun fichier n'a pu être supprimé."

#: guest-upload-vault/templates/admin-page.php:145
msgid "No encrypted files are currently available."
msgstr "Aucun fichier crypté n'est actuellement disponible."

#: guest-upload-vault/templates/admin-page.php:149
msgid "Bulk ZIP download is not available on this server (ZipArchive missing)."
msgstr ""
"Le téléchargement ZIP en masse n'est pas disponible sur ce serveur "
"(ZipArchive manquant)."

#: guest-upload-vault/templates/admin-page.php:153
msgid "Could not create ZIP archive. Please try again."
msgstr "Impossible de créer l'archive ZIP. Veuillez réessayer."

#: guest-upload-vault/templates/admin-page.php:157
msgid "No files could be added to ZIP download."
msgstr "Aucun fichier n'a pu être ajouté au téléchargement ZIP."

#: guest-upload-vault/templates/admin-page.php:161
msgid "Media diagnostics were refreshed."
msgstr "Les diagnostics des médias ont été actualisés."

#. translators: 1: configured MB, 2: runtime cap MB
#: guest-upload-vault/templates/admin-page.php:171
#, php-format
msgid ""
"Current configured max is %1$d MB, but this server can safely handle up to "
"%2$d MB. Uploads are limited to the lower value."
msgstr ""
"Le maximum actuellement configuré est %1$d MB, mais ce serveur peut gérer en "
"toute sécurité jusqu'à %2$d MB. Les téléchargements sont limités à la valeur "
"inférieure."

#. translators: %d: legacy file count
#: guest-upload-vault/templates/admin-page.php:186
#, php-format
msgid ""
"Detected %d legacy plaintext file(s). They are no longer served by this "
"plugin. Migrate or remove them from uploads/guest-upload-vault."
msgstr ""
"%d fichier(s) texte brut hérité a été détecté. Ils ne sont plus servis par "
"ce plugin. Migrez-les ou supprimez-les de uploads/guest-upload-vault."

#: guest-upload-vault/templates/admin-page.php:196
msgid ""
"Encryption key status is unhealthy. Media uploads/downloads may fail until "
"the key configuration is repaired."
msgstr ""
"L’état de la clé de chiffrement n’est pas sain. Les téléchargements "
"multimédias peuvent échouer jusqu'à ce que la configuration des clés soit "
"réparée."

#. translators: %d: affected files count
#: guest-upload-vault/templates/admin-page.php:206
#, php-format
msgid ""
"%d encrypted file(s) are missing metadata. Those files cannot be downloaded "
"until metadata is restored."
msgstr ""
"Il manque des métadonnées dans %d fichier(s) chiffré(s). Ces fichiers ne "
"peuvent pas être téléchargés tant que les métadonnées ne sont pas restaurées."

#. translators: %d: affected files count
#: guest-upload-vault/templates/admin-page.php:220
#, php-format
msgid ""
"%d file(s) have damaged or unreadable metadata. Download may fail until "
"repaired from backup."
msgstr ""
"Les fichiers %d contiennent des métadonnées endommagées ou illisibles. Le "
"téléchargement peut échouer jusqu'à ce qu'il soit réparé à partir de la "
"sauvegarde."

#. translators: %d: affected files count
#: guest-upload-vault/templates/admin-page.php:234
#, php-format
msgid ""
"%d file(s) failed metadata integrity checks. They may have been modified or "
"corrupted."
msgstr ""
"Les contrôles d'intégrité des métadonnées du ou des fichiers %d ont échoué. "
"Ils peuvent avoir été modifiés ou corrompus."

#. translators: %d: affected files count
#: guest-upload-vault/templates/admin-page.php:248
#, php-format
msgid ""
"%d file(s) require an encryption key version that is not available on this "
"site."
msgstr ""
"Les fichiers %d nécessitent une version de clé de cryptage qui n'est pas "
"disponible sur ce site."

#. translators: %d: affected files count
#: guest-upload-vault/templates/admin-page.php:262
#, php-format
msgid ""
"%d file(s) still use legacy plaintext metadata. They remain downloadable, "
"but re-uploading improves privacy."
msgstr ""
"Les fichiers %d utilisent toujours des métadonnées en texte brut héritées. "
"Ils restent téléchargeables, mais le nouveau téléchargement améliore la "
"confidentialité."

#. translators: %d: affected files count
#: guest-upload-vault/templates/admin-page.php:276
#, php-format
msgid ""
"%d file(s) failed the decryption health check. The encrypted file or "
"metadata may be corrupted."
msgstr ""
"Le(s) fichier(s) %d ont échoué lors de la vérification de l'état de "
"déchiffrement. Le fichier chiffré ou les métadonnées peuvent être corrompus."

#: guest-upload-vault/templates/admin-page.php:295
msgid "Upload Page URL"
msgstr "URL de la page de téléchargement"

#. translators: %s: shortcode
#: guest-upload-vault/templates/admin-page.php:310
#, php-format
msgid "Add shortcode %s to this page."
msgstr "Ajoutez le shortcode %s à cette page."

#: guest-upload-vault/templates/admin-page.php:319
msgid "Access Token"
msgstr "Jeton d'accès"

#: guest-upload-vault/templates/admin-page.php:331
msgid "Regenerate Guest Link"
msgstr "Régénérer le lien invité"

#: guest-upload-vault/templates/admin-page.php:335
msgid ""
"Anyone with the protected link can upload. Regenerating token invalidates "
"old links and QR prints."
msgstr ""
"Toute personne disposant du lien protégé peut télécharger. La régénération "
"du jeton invalide les anciens liens et les impressions QR."

#: guest-upload-vault/templates/admin-page.php:341
msgid "Max Upload Size (MB)"
msgstr "Taille maximale de téléchargement (MB)"

#. translators: 1: allowed file types, 2: effective MB
#: guest-upload-vault/templates/admin-page.php:356
#, php-format
msgid "Allowed file types: %1$s. Effective per-file limit: %2$d MB."
msgstr ""
"Types de fichiers autorisés: %1$s. Limite effective par fichier: %2$d MB."

#. translators: 1: upload_max_filesize MB, 2: post_max_size MB, 3: memory_limit MB, 4: memory-safe MB
#: guest-upload-vault/templates/admin-page.php:366
#, php-format
msgid ""
"Runtime limits (MB): upload_max_filesize=%1$d, post_max_size=%2$d, "
"memory_limit=%3$d, memory-safe ceiling=%4$d."
msgstr ""
"Limites d'exécution (MB): upload_max_filesize=%1$d, post_max_size=%2$d, "
"memory_limit=%3$d, plafond de sécurité mémoire=%4$d."

#: guest-upload-vault/templates/admin-page.php:378
msgid "Cleanup On Uninstall"
msgstr "Nettoyage lors de la désinstallation"

#: guest-upload-vault/templates/admin-page.php:389
msgid ""
"Yes, permanently delete guest media + metadata from uploads/guest-upload-"
"vault when uninstalling this plugin."
msgstr "Oui, supprimez définitivement les médias invités + métadonnées de uploads/guest-upload-vault lors de la désinstallation de cette extension."

#: guest-upload-vault/templates/admin-page.php:392
msgid "Leave unchecked to keep files on disk after uninstall."
msgstr ""
"Laissez décochée pour conserver les fichiers sur le disque après la "
"désinstallation."

#: guest-upload-vault/templates/admin-page.php:395
msgid "This setting has no effect on normal plugin deactivation."
msgstr "Ce paramètre n'a aucun effet sur la désactivation normale du plugin."

#: guest-upload-vault/templates/admin-page.php:400
msgid "Encryption Key"
msgstr "Clé de cryptage"

#. translators: 1: healthy/unhealthy, 2: version, 3: key fingerprint
#: guest-upload-vault/templates/admin-page.php:406
#, php-format
msgid "Status: %1$s | Version: %2$d | Fingerprint: %3$s"
msgstr "Statut: %1$s | Version: %2$d | Empreinte digitale: %3$s"

#: guest-upload-vault/templates/admin-page.php:407
#: guest-upload-vault/templates/admin-page.php:572
msgid "Healthy"
msgstr "En bonne santé"

#: guest-upload-vault/templates/admin-page.php:407
msgid "Problem"
msgstr "Problème"

#: guest-upload-vault/templates/admin-page.php:414
msgid ""
"Backup requirement: keep database/plugin options and uploads/guest-upload-"
"vault together in the same backup/restore set. Restoring only one can make "
"media undecryptable."
msgstr ""
"Exigence de sauvegarde: conservez les options de base de données/plug-in et "
"uploads/guest-upload-vault ensemble dans le même ensemble de sauvegarde/"
"restauration. En restaurer un seul peut rendre le média indéchiffrable."

#: guest-upload-vault/templates/admin-page.php:417
msgid ""
"Operational tip: verify restores on a staging site before the event date."
msgstr ""
"Conseil opérationnel: vérifiez les restaurations sur un site intermédiaire "
"avant la date de l'événement."

